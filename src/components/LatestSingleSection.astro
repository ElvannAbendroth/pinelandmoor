---
import { cn } from '@/lib/utils'
import { buttonVariants } from './ui/button'

const { spotifyUrl, imageSrc, alt, cardStyle, sectionId, title, description, buttonText, gridInverted } = Astro.props
---

<section
  id={sectionId}
  class={`flex flex-col items-center justify-center gap-4 p-2 px-6 py-8 sm:py-20 sm:px-10 relative ${cardStyle}`}
>
  <div class={`grid grid-cols-1 md:grid-cols-2 max-w-3xl gap-6 `}>
    <a href={spotifyUrl} target="_blank" class={gridInverted ? 'order-last' : 'flex justify-center'}>
      <img src={imageSrc} class="rounded-xl shadow-2xl hover:scale-105 transition-all" alt={alt} />
    </a>

    <div class="flex flex-col gap-6 items-center md:items-start justify-center text-center md:text-left">
      <h2 class="typo-h2">{title}</h2>
      <p class="typo-p">{description}</p>

      <a
        class={cn(buttonVariants({ variant: 'default' }), 'bg-spotify hover:bg-spotify/90 rounded-full')}
        href={spotifyUrl}
        target="_blank"
      >
        {buttonText}
      </a>
    </div>
  </div>
</section>
