---
import Layout from '@/layouts/Layout.astro'
import ContactForm from '@/components/ContactForm'
import { fade } from 'astro:transitions'

export const prerender = true
---

<Layout title="Welcome to this Astro Starter Template!">
  <section class="flex flex-col items-center justify-center gap-4 min-h-[calc(100vh-20rem)]">
    <h1 transition:name="title" class="typo-h1">Contact</h1>

    <p class="typo-p">Send us a message and we'll get back to you soon!</p>
    <ContactForm client:load />
  </section>
</Layout>
